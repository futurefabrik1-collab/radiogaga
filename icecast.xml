<icecast>
  <location>radiogaga.ai</location>
  <admin>admin@radiogaga.ai</admin>

  <limits>
    <clients>100</clients>
    <sources>2</sources>
    <queue-size>524288</queue-size>
    <client-timeout>30</client-timeout>
    <header-timeout>15</header-timeout>
    <source-timeout>10</source-timeout>
    <burst-on-connect>1</burst-on-connect>
    <burst-size>65536</burst-size>
  </limits>

  <authentication>
    <source-password>radiogaga_source</source-password>
    <relay-password>radiogaga_relay</relay-password>
    <admin-user>admin</admin-user>
    <admin-password>radiogaga_admin</admin-password>
  </authentication>

  <hostname>localhost</hostname>

  <listen-socket>
    <port>8000</port>
  </listen-socket>

  <http-headers>
    <header name="Access-Control-Allow-Origin" value="*" />
    <header name="Access-Control-Allow-Headers" value="Origin, Accept, X-Requested-With" />
    <header name="Access-Control-Allow-Methods" value="GET, OPTIONS" />
  </http-headers>

  <mount type="normal">
    <mount-name>/stream</mount-name>
    <stream-name>radioGAGA</stream-name>
    <stream-description>AI-powered 24/7 radio</stream-description>
    <stream-url>https://www.radiogaga.ai</stream-url>
    <genre>Electronic / Spoken Word / AI</genre>
    <public>0</public>
  </mount>

  <fileserve>1</fileserve>

  <paths>
    <basedir>/opt/homebrew/share/icecast</basedir>
    <logdir>/tmp/icecast-logs</logdir>
    <webroot>/opt/homebrew/share/icecast/web</webroot>
    <adminroot>/opt/homebrew/share/icecast/admin</adminroot>
    <pidfile>/tmp/icecast.pid</pidfile>
  </paths>

  <logging>
    <accesslog>access.log</accesslog>
    <errorlog>error.log</errorlog>
    <loglevel>3</loglevel>
  </logging>

  <security>
    <chroot>0</chroot>
  </security>
</icecast>
